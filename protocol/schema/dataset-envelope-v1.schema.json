{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainingembers.org/schemas/embersync/dataset-envelope-v1.schema.json",
  "title": "EmberSync upload dataset envelope v1",
  "type": "object",
  "required": ["schemaVersion", "protocolVersion", "dataset", "kind", "scope", "subjectId", "guildKey", "guild", "sourceCharacter", "installationId", "exportSequence", "capturedAt", "persistedAt", "coverage", "payloadHash", "payload"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocolVersion": { "const": "1.0" },
    "dataset": { "$ref": "common-v1.schema.json#/$defs/uploadDatasetName" },
    "kind": { "enum": ["state", "events"] },
    "scope": { "$ref": "common-v1.schema.json#/$defs/datasetScope" },
    "subjectId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "guildKey": { "$ref": "common-v1.schema.json#/$defs/guildKey" },
    "guild": { "$ref": "common-v1.schema.json#/$defs/canonicalGuild" },
    "sourceCharacter": { "$ref": "common-v1.schema.json#/$defs/sourceCharacter" },
    "installationId": { "$ref": "common-v1.schema.json#/$defs/installationId" },
    "exportSequence": { "type": "integer", "minimum": 1 },
    "capturedAt": { "$ref": "common-v1.schema.json#/$defs/utcInstant" },
    "persistedAt": { "type": "integer", "minimum": 1 },
    "coverage": { "$ref": "common-v1.schema.json#/$defs/coverage" },
    "permissionEvidence": { "$ref": "common-v1.schema.json#/$defs/permissionEvidence" },
    "eventRange": {
      "type": "object",
      "required": ["firstSequence", "lastSequence"],
      "properties": {
        "firstSequence": { "type": "integer", "minimum": 1 },
        "lastSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "payloadHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" },
    "payload": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
  },
  "$defs": {
    "eventBatchPayload": {
      "type": "object",
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "maxItems": 250,
          "items": {
            "type": "object",
            "required": ["sequence", "capturedAt", "payload"],
            "properties": {
              "sequence": { "type": "integer", "minimum": 1 },
              "capturedAt": { "type": "integer", "minimum": 1 },
              "payload": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "guildCalendarEventInfo": {
      "type": "object",
      "required": ["calendarType"],
      "properties": {
        "calendarType": { "enum": ["GUILD_EVENT", "GUILD_ANNOUNCEMENT"] }
      },
      "additionalProperties": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
    },
    "guildCalendarDayEvent": {
      "type": "object",
      "required": ["monthOffset", "day", "index", "info", "privacyClass"],
      "properties": {
        "monthOffset": { "type": "integer", "minimum": -24, "maximum": 24 },
        "day": { "type": "integer", "minimum": 1, "maximum": 31 },
        "index": { "type": "integer", "minimum": 1, "maximum": 100 },
        "info": { "$ref": "#/$defs/guildCalendarEventInfo" },
        "privacyClass": { "const": "guild" }
      },
      "additionalProperties": false
    },
    "guildCalendarOpenedEvent": {
      "type": "object",
      "required": ["info", "invites", "observedAt", "privacyClass"],
      "properties": {
        "info": { "$ref": "#/$defs/guildCalendarEventInfo" },
        "invites": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
        },
        "observedAt": { "type": "number", "minimum": 0 },
        "privacyClass": { "const": "guild" }
      },
      "additionalProperties": false
    },
    "guildCalendarPayload": {
      "type": "object",
      "required": ["months", "events", "guildEvents", "openedEventDetails", "initialization"],
      "properties": {
        "months": {
          "type": "array",
          "maxItems": 24,
          "items": {
            "type": "object",
            "required": ["month", "year"],
            "properties": {
              "month": { "type": "integer", "minimum": 1, "maximum": 12 },
              "year": { "type": "integer", "minimum": 2000, "maximum": 2200 },
              "numDays": { "type": "integer", "minimum": 28, "maximum": 31 },
              "firstWeekday": { "type": "integer", "minimum": 1, "maximum": 7 }
            },
            "additionalProperties": false
          }
        },
        "events": {
          "type": "array",
          "maxItems": 1400,
          "items": { "$ref": "#/$defs/guildCalendarDayEvent" }
        },
        "guildEvents": {
          "$comment": "Runtime validation additionally requires this array to be canonically identical to events.",
          "type": "array",
          "maxItems": 1400,
          "items": { "$ref": "#/$defs/guildCalendarDayEvent" }
        },
        "lastOpenedEvent": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/guildCalendarOpenedEvent" }
          ]
        },
        "openedEventDetails": {
          "type": "object",
          "maxProperties": 200,
          "additionalProperties": { "$ref": "#/$defs/guildCalendarOpenedEvent" }
        },
        "initialization": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "maxLength": 40 },
            "observedAt": { "type": "number", "minimum": 0 },
            "readyAt": { "type": "number", "minimum": 0 },
            "openSupported": { "type": "boolean" },
            "openRequested": { "type": "boolean" },
            "retainedLastGood": { "type": "boolean" },
            "lastGoodCapturedAt": {
              "oneOf": [
                { "type": "number", "minimum": 0 },
                { "type": "string", "maxLength": 64 }
              ]
            },
            "interactionRequired": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "events" } } },
      "then": {
        "required": ["eventRange"],
        "properties": {
          "kind": { "const": "events" },
          "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedEventDatasetName" },
          "scope": { "const": "guild" },
          "subjectId": { "pattern": "^[A-Za-z0-9_-]{16}:Player-[0-9]+-[0-9A-Fa-f]+:[1-9][0-9]*$" },
          "payload": { "$ref": "#/$defs/eventBatchPayload" }
        }
      },
      "else": {
        "properties": {
          "kind": { "const": "state" },
          "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedStateDatasetName" },
          "eventRange": false
        }
      }
    },
    {
      "if": {
        "properties": { "dataset": { "const": "calendar" } },
        "required": ["dataset"]
      },
      "then": {
        "properties": {
          "kind": { "const": "state" },
          "scope": { "const": "guild" },
          "payload": { "$ref": "#/$defs/guildCalendarPayload" }
        }
      }
    }
  ],
  "additionalProperties": true
}
