{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainingembers.org/schemas/embersync/dataset-envelope-v1.schema.json",
  "title": "EmberSync upload dataset envelope v1",
  "type": "object",
  "required": ["schemaVersion", "protocolVersion", "dataset", "kind", "scope", "subjectId", "guildKey", "guild", "sourceCharacter", "installationId", "exportSequence", "capturedAt", "persistedAt", "coverage", "payloadHash", "payload"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocolVersion": { "const": "1.0" },
    "dataset": { "$ref": "common-v1.schema.json#/$defs/uploadDatasetName" },
    "kind": { "enum": ["state", "events"] },
    "scope": { "$ref": "common-v1.schema.json#/$defs/datasetScope" },
    "subjectId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "guildKey": { "$ref": "common-v1.schema.json#/$defs/guildKey" },
    "guild": { "$ref": "common-v1.schema.json#/$defs/canonicalGuild" },
    "sourceCharacter": { "$ref": "common-v1.schema.json#/$defs/sourceCharacter" },
    "installationId": { "$ref": "common-v1.schema.json#/$defs/installationId" },
    "exportSequence": { "type": "integer", "minimum": 1 },
    "capturedAt": { "$ref": "common-v1.schema.json#/$defs/utcInstant" },
    "persistedAt": { "type": "integer", "minimum": 1 },
    "coverage": { "$ref": "common-v1.schema.json#/$defs/coverage" },
    "permissionEvidence": { "$ref": "common-v1.schema.json#/$defs/permissionEvidence" },
    "eventRange": {
      "type": "object",
      "required": ["firstSequence", "lastSequence"],
      "properties": {
        "firstSequence": { "type": "integer", "minimum": 1 },
        "lastSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "payloadHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" },
    "payload": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
  },
  "$defs": {
    "eventBatchPayload": {
      "type": "object",
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "maxItems": 250,
          "items": {
            "type": "object",
            "required": ["sequence", "capturedAt", "payload"],
            "properties": {
              "sequence": { "type": "integer", "minimum": 1 },
              "capturedAt": { "type": "integer", "minimum": 1 },
              "payload": { "$ref": "common-v1.schema.json#/$defs/jsonValue" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "events" } } },
      "then": {
        "required": ["eventRange"],
        "properties": {
          "kind": { "const": "events" },
          "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedEventDatasetName" },
          "scope": { "const": "guild" },
          "subjectId": { "pattern": "^[A-Za-z0-9_-]{16}:Player-[0-9]+-[0-9A-Fa-f]+:[1-9][0-9]*$" },
          "payload": { "$ref": "#/$defs/eventBatchPayload" }
        }
      },
      "else": {
        "properties": {
          "kind": { "const": "state" },
          "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedStateDatasetName" },
          "eventRange": false
        }
      }
    }
  ],
  "additionalProperties": true
}
