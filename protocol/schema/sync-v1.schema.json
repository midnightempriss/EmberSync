{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rainingembers.org/schemas/embersync/sync-v1.schema.json",
  "title": "EmberSync sync start request v1",
  "$ref": "#/$defs/syncStartRequest",
  "$defs": {
    "eventRange": {
      "type": "object",
      "required": ["firstSequence", "lastSequence"],
      "properties": {
        "firstSequence": { "type": "integer", "minimum": 1 },
        "lastSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "segment": {
      "type": "object",
      "required": ["dataset", "kind", "scope", "subjectId", "coverage", "payloadHash", "envelopeHash", "compressedBytes", "expandedBytes"],
      "properties": {
        "dataset": { "$ref": "common-v1.schema.json#/$defs/uploadDatasetName" },
        "kind": { "enum": ["state", "events"] },
        "scope": { "$ref": "common-v1.schema.json#/$defs/datasetScope" },
        "subjectId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "coverage": { "$ref": "common-v1.schema.json#/$defs/coverage" },
        "payloadHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" },
        "envelopeHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" },
        "compressedBytes": { "type": "integer", "minimum": 0, "maximum": 1048576 },
        "expandedBytes": { "type": "integer", "minimum": 0, "maximum": 8388608 },
        "eventRange": { "$ref": "#/$defs/eventRange" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "events" } } },
          "then": {
            "required": ["eventRange"],
            "properties": {
              "kind": { "const": "events" },
              "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedEventDatasetName" },
              "scope": { "const": "guild" },
              "subjectId": { "pattern": "^[A-Za-z0-9_-]{16}:Player-[0-9]+-[0-9A-Fa-f]+:[1-9][0-9]*$" }
            }
          },
          "else": {
            "properties": {
              "kind": { "const": "state" },
              "dataset": { "$ref": "common-v1.schema.json#/$defs/boundedStateDatasetName" },
              "eventRange": false
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "manifest": {
      "type": "object",
      "required": ["schemaVersion", "protocolVersion", "guildKey", "guild", "sourceCharacter", "installationId", "exportSequence", "capturedAt", "persistedAt", "queuedAt", "segments"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "protocolVersion": { "const": "1.0" },
        "guildKey": { "$ref": "common-v1.schema.json#/$defs/guildKey" },
        "guild": { "$ref": "common-v1.schema.json#/$defs/canonicalGuild" },
        "sourceCharacter": { "$ref": "common-v1.schema.json#/$defs/sourceCharacter" },
        "installationId": { "$ref": "common-v1.schema.json#/$defs/installationId" },
        "exportSequence": { "type": "integer", "minimum": 1 },
        "capturedAt": { "$ref": "common-v1.schema.json#/$defs/utcInstant" },
        "persistedAt": { "type": "integer", "minimum": 1 },
        "queuedAt": { "type": "integer", "minimum": 1 },
        "segments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/segment" }
        }
      },
      "additionalProperties": true
    },
    "syncStartRequest": {
      "type": "object",
      "required": ["manifest", "manifestHash"],
      "properties": {
        "manifest": { "$ref": "#/$defs/manifest" },
        "manifestHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" }
      },
      "additionalProperties": true
    },
    "syncStartResponse": {
      "type": "object",
      "required": ["sessionId", "expiresAt", "missingEnvelopeHashes", "maxCompressedChunkBytes", "maxExpandedChunkBytes", "remainingCompressedSessionBytes"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 16, "maxLength": 128 },
        "expiresAt": { "$ref": "common-v1.schema.json#/$defs/utcInstant" },
        "missingEnvelopeHashes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" }
        },
        "maxCompressedChunkBytes": { "const": 1048576 },
        "maxExpandedChunkBytes": { "const": 8388608 },
        "remainingCompressedSessionBytes": { "type": "integer", "minimum": 0, "maximum": 67108864 }
      },
      "additionalProperties": true
    },
    "syncCommitRequest": {
      "type": "object",
      "required": ["manifestHash"],
      "properties": {
        "manifestHash": { "$ref": "common-v1.schema.json#/$defs/sha256Hex" }
      },
      "additionalProperties": true
    },
    "syncCommitResponse": {
      "type": "object",
      "required": ["status", "committedAt", "acceptedSequence"],
      "properties": {
        "status": { "enum": ["committed", "already_committed"] },
        "committedAt": { "$ref": "common-v1.schema.json#/$defs/utcInstant" },
        "acceptedSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    }
  }
}
